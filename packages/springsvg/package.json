{
  "name": "springsvg",
  "version": "0.1.0",
  "description": "Spring physics-based SVG drawing animation library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "biome check ./src",
    "format": "biome format --write ./src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "svg",
    "animation",
    "spring",
    "physics",
    "drawing"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
